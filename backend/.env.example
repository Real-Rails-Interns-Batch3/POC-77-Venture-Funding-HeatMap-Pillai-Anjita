# Real Rails — Venture Funding Heatmap
# Copy this file to .env and fill in your keys

# Mapbox token (required for GL map tiles)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Crunchbase API key (optional — system falls back to mock data automatically)
CRUNCHBASE_API_KEY=

# World Bank API (public, no key needed but can set for rate-limit bypass)
WORLD_BANK_API_BASE=https://api.worldbank.org/v2

# FastAPI server config
API_HOST=0.0.0.0
API_PORT=8000